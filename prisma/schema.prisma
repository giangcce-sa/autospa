generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id          String    @id @default(cuid())
  email       String    @unique
  name        String?
  hashedPwd   String                                  // bcrypt
  role        String    @default("owner")             // owner | viewer
  lastLoginAt DateTime?
  createdAt   DateTime  @default(now())
}

model RateLimit {
  id          String   @id                            // composite: "provider:scope"
  count       Int      @default(0)
  windowStart DateTime
  limit       Int                                      // configured cap
  windowSec   Int                                      // window size in seconds
  updatedAt   DateTime @updatedAt
}

model Settings {
  id            String   @id @default("1")
  claudeApiKey  String?
  claudeBaseUrl String   @default("https://api.anthropic.com")
  openaiApiKey  String?
  openaiBaseUrl String   @default("https://api.openai.com/v1")
  imageModel    String   @default("dall-e-3")
  openaiChatModel String @default("gpt-5")        // chat completion model for AI Council
  zaloToken              String?
  zaloOaId               String?
  draftRetentionDays     Int      @default(30)
  publishedRetentionDays Int      @default(90)
  webhookVerifyToken     String   @default("")
  webhookMode            String   @default("manual")
  autoReplyComments      Boolean  @default(false)
  autoReplyMessages      Boolean  @default(false)
  // Spa Software Integration
  spaApiUrl              String?
  spaApiKey              String?
  spaWebhookSecret       String?
  // Lead Handoff
  leadHandoffMode        String   @default("staff")       // "link" | "api" | "staff"
  leadHandoffLink        String?
  // Automation
  automationLevel        String   @default("supervised")  // "supervised" | "semi" | "full"
  zaloApprovalRecipient  String?
  // Ads Optimization Thresholds
  adsOptimizePauseCtr    Float    @default(0.5)
  adsOptimizeScaleCtr    Float    @default(2.0)
  adsOptimizeFreqLimit   Float    @default(3.0)
  adsOptimizeScalePct    Int      @default(20)
  // Telegram
  telegramBotToken       String?
  telegramChatId         String?
  telegramAlerts         Boolean  @default(true)
  weeklyReportEnabled    Boolean  @default(true)
  weeklyReportDay        Int      @default(1)
  weeklyReportHour       Int      @default(8)
  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
}

model FacebookPage {
  id           String   @id @default(cuid())
  fbPageId     String   @unique
  pageName     String
  accessToken  String
  isActive     Boolean  @default(true)
  adAccountId  String?
  createdAt    DateTime @default(now())

  posts         Post[]
  comments      PostComment[]
  inboxMessages InboxMessage[]
  brandKit      BrandKit?
  styleProfile  StyleProfile?
  styleSamples  StyleSample[]
  services      Service[]
}

model BrandKnowledge {
  id        String   @id @default(cuid())
  category  String
  title     String
  content   String
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BrandKit {
  id             String        @id @default(cuid())
  facebookPageId String?       @unique
  facebookPage   FacebookPage? @relation(fields: [facebookPageId], references: [id])
  logoUrl        String?
  primaryColor   String        @default("#2d6a4f")
  accentColor    String        @default("#40c074")
  fontStyle      String        @default("elegant")
  spaName        String?
  tagline        String?
  updatedAt      DateTime      @updatedAt
}

model Service {
  id             String        @id @default(cuid())
  facebookPageId String?
  facebookPage   FacebookPage? @relation(fields: [facebookPageId], references: [id])
  name           String
  description    String?
  price          String?
  category       String?
  duration       String?
  active         Boolean       @default(true)
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
  posts          Post[]
}

model StyleSample {
  id             String        @id @default(cuid())
  facebookPageId String?
  facebookPage   FacebookPage? @relation(fields: [facebookPageId], references: [id])
  content        String
  platform       String        @default("facebook")
  likes          Int           @default(0)
  comments       Int           @default(0)
  shares         Int           @default(0)
  source         String        @default("manual")
  createdAt      DateTime      @default(now())
}

model StyleProfile {
  id             String        @id @default(cuid())
  facebookPageId String?       @unique
  facebookPage   FacebookPage? @relation(fields: [facebookPageId], references: [id])
  profile        String
  updatedAt      DateTime      @updatedAt
}

model Post {
  id           String          @id @default(cuid())
  caption      String
  hashtags     String?
  imageUrl     String?
  imagePrompt  String?
  platform     String          @default("facebook")
  postType     String          @default("service")
  tone         String          @default("friendly")
  status       String          @default("draft")
  scheduledAt  DateTime?
  publishedAt  DateTime?
  fbPostId     String?
  fbAdId       String?
  fbCampaignId String?
  qualityScore Int?
  qualityNotes String?
  abGroupId    String?
  serviceId      String?
  bulkPlanId     String?
  facebookPageId String?
  service        Service?        @relation(fields: [serviceId], references: [id])
  bulkPlan       BulkPlan?       @relation(fields: [bulkPlanId], references: [id])
  facebookPage   FacebookPage?   @relation(fields: [facebookPageId], references: [id])
  analytics    PostAnalytics?
  review       ContentReview?
  comments     PostComment[]
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
}

model BulkPlan {
  id          String   @id @default(cuid())
  name        String
  month       Int
  year        Int
  status      String   @default("draft")
  posts       Post[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ContentReview {
  id          String   @id @default(cuid())
  postId      String   @unique
  post        Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  status      String                                 // "pass" | "warn" | "fail"
  score       Int      @default(0)                   // 0-100
  issues      String                                 // JSON: [{ type, severity, message, suggestion }]
  reviewer    String   @default("ai_reviewer")
  reviewedAt  DateTime @default(now())
}

model PostAnalytics {
  id        String   @id @default(cuid())
  postId    String   @unique
  post      Post     @relation(fields: [postId], references: [id], onDelete: Cascade)
  reach     Int      @default(0)
  likes     Int      @default(0)
  comments  Int      @default(0)
  shares    Int      @default(0)
  clicks    Int      @default(0)
  fetchedAt DateTime @default(now())
}

model PostComment {
  id             String        @id @default(cuid())
  postId         String
  post           Post          @relation(fields: [postId], references: [id], onDelete: Cascade)
  facebookPageId String?
  facebookPage   FacebookPage? @relation(fields: [facebookPageId], references: [id])
  fbCommentId    String?
  authorName     String
  content        String
  sentiment      String?
  isReplied      Boolean       @default(false)
  autoReply      String?
  isAlert        Boolean       @default(false)
  createdAt      DateTime      @default(now())
}

model CommentRule {
  id        String   @id @default(cuid())
  trigger   String
  reply     String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model MessageRule {
  id        String   @id @default(cuid())
  trigger   String                                // keyword hoặc regex pattern
  reply     String                                // text trả lời cố định
  matchMode String   @default("contains")        // contains | exact | regex
  priority  Int      @default(0)                  // rule cao hơn match trước
  channel   String   @default("both")            // facebook | zalo | both
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
}

model InboxMessage {
  id             String        @id @default(cuid())
  senderId       String
  senderName     String
  message        String
  reply          String?
  isRead         Boolean       @default(false)
  isAutoReply    Boolean       @default(false)
  customerId     String?
  facebookPageId String?
  customer       Customer?     @relation(fields: [customerId], references: [id])
  facebookPage   FacebookPage? @relation(fields: [facebookPageId], references: [id])
  createdAt      DateTime      @default(now())
}

model AppointmentRequest {
  id          String    @id @default(cuid())
  name        String
  phone       String?
  service     String?
  preferredAt String?
  note        String?
  status      String    @default("pending")
  source      String    @default("inbox")
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Customer {
  id           String               @id @default(cuid())
  name         String
  phone        String?
  fbId         String?
  fbName       String?
  email        String?
  birthday     String?
  segment      String               @default("new")
  leadScore    Int                  @default(0)
  lastContact  DateTime?
  note         String?
  tags         String?
  npsScore     Int?
  npsAt        DateTime?
  createdAt    DateTime             @default(now())
  updatedAt    DateTime             @updatedAt
  messages     InboxMessage[]
  appointments AppointmentRequest[]
  notes        CustomerNote[]
  careMessages CareMessage[]
}

model CustomerNote {
  id         String   @id @default(cuid())
  customerId String
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
  content    String
  type       String   @default("note")
  createdAt  DateTime @default(now())
}

model CareMessage {
  id          String    @id @default(cuid())
  customerId  String?
  customer    Customer? @relation(fields: [customerId], references: [id])
  type        String
  content     String
  platform    String    @default("facebook")
  scheduledAt DateTime?
  sentAt      DateTime?
  status      String    @default("pending")
  createdAt   DateTime  @default(now())
}

model Competitor {
  id          String   @id @default(cuid())
  fbPageId    String   @unique           // public page ID (e.g. "12345...")
  name        String                     // tên đối thủ (do user nhập)
  notes       String?                    // ghi chú nội bộ
  accessToken String?                    // optional — page access token nếu có
  isActive    Boolean  @default(true)
  lastFetchAt DateTime?
  createdAt   DateTime @default(now())
  posts       CompetitorPost[]
}

model CompetitorPost {
  id           String     @id @default(cuid())
  competitorId String
  competitor   Competitor @relation(fields: [competitorId], references: [id], onDelete: Cascade)
  fbPostId     String     @unique
  message      String
  likes        Int        @default(0)
  comments     Int        @default(0)
  shares       Int        @default(0)
  publishedAt  DateTime
  fetchedAt    DateTime   @default(now())
}

model IntelligenceSignal {
  id        String   @id @default(cuid())
  source    String                            // "fb_ads_library" | "google_trends" | "fb_competitor" | "manual"
  topic     String                            // "triệt lông bikini", "facial Hàn Quốc"
  volume    Float                             // search index | active ads count | likes
  trend     String   @default("stable")       // "rising" | "stable" | "falling"
  details   String?                            // JSON: raw data
  fetchedAt DateTime @default(now())

  @@index([source, topic])
  @@index([trend, fetchedAt])
}

model SpaStory {
  id             String   @id @default(cuid())
  facebookPageId String?
  type           String   @default("testimonial") // testimonial | result | event | staff | behind-scenes
  customerName   String?
  content        String
  service        String?
  imageUrl       String?
  isActive       Boolean  @default(true)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model RealtimeAlert {
  id            String   @id @default(cuid())
  type          String                          // "revenue_drop" | "negative_spike" | "ad_anomaly" | "lead_pile"
  signal        String                          // detail string
  severity      String                          // "warning" | "critical"
  workflowRunId String?                          // if a workflow was triggered
  acknowledged  Boolean  @default(false)
  detectedAt    DateTime @default(now())

  @@index([type, detectedAt])
  @@index([acknowledged])
}

model WorkflowRun {
  id          String   @id @default(cuid())
  name        String                          // "revenue_drop" | "competitor_surge" | "engagement_drop"
  trigger     String                          // signal label
  context     String                          // full context
  steps       String                          // JSON: [{ agent, label, input, output, status, durationMs }]
  plan        String?                         // CEO synthesis output
  status      String   @default("running")    // running | completed | failed
  startedAt   DateTime @default(now())
  completedAt DateTime?

  @@index([name, startedAt])
  @@index([status])
}

model OrchestratorRun {
  id          String   @id @default(cuid())
  runAt       DateTime @default(now())
  signals     String                            // JSON state snapshot
  priorities  String                            // JSON [{ agent, score, reason }]
  actions     String                            // JSON actions taken/queued
  mode        String   @default("recommend")    // recommend | auto
}

model CEODecision {
  id              String   @id @default(cuid())
  date            DateTime @default(now())
  topic           String                          // chủ đề (dùng để fuzzy match khi truy vấn)
  topicKey        String                          // normalized: lowercase + keywords (cho query nhanh)
  context         String                          // bối cảnh input
  synthesis       String                          // quyết định cuối từ Council
  debate          String?                         // JSON turns transcript
  source          String   @default("council")    // council | morning_brief | content_research | ab_test | manual
  // Outcome tracking
  outcomeCheckAt  DateTime?                       // khi nào sẽ check kết quả (date + N ngày)
  outcomeMetric   String?                         // metric đo (revenue | leads | engagement)
  outcomeBefore   Float?                          // baseline trước
  outcomeAfter    Float?                          // sau X ngày
  outcomeStatus   String?                         // "success" | "fail" | "neutral" | "pending"
  outcomeNotes    String?                         // AI nhận định
  createdAt       DateTime @default(now())

  @@index([topicKey])
  @@index([outcomeStatus])
}

model RevenueForecast {
  id             String   @id @default(cuid())
  generatedAt    DateTime @default(now())
  horizonDays    Int
  scenario       String   @default("baseline")  // baseline | ads_2x | promo_30 | tet_boost
  forecast       String                          // JSON array: [{ date, predicted, lowerBound, upperBound, factors }]
  totalPredicted Int                             // sum of predicted across horizon (VND)
  confidence     Float    @default(0.5)          // 0.0-1.0
  notes          String?                          // AI Council reasoning
}

model MorningBrief {
  id          String   @id @default(cuid())
  date        String   @unique
  summary     String                        // CEO synthesis
  actions     String                        // JSON BriefAction[] — legacy compat
  debate      String?                       // JSON CouncilTurn[]
  subReports  String?                       // JSON { intelligence, ads, content, sales }
  assignments String?                       // JSON Assignment[]
  dismissed   Boolean  @default(false)
  createdAt   DateTime @default(now())
}

model HolidayEvent {
  id          String   @id @default(cuid())
  name        String
  date        String
  description String?
  isVietnamese Boolean @default(true)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
}

model SocialAlert {
  id        String   @id @default(cuid())
  type      String
  content   String
  source    String
  severity  String   @default("low")
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())
}

model Lead {
  id           String   @id @default(cuid())
  customerId   String?
  name         String
  phone        String?
  source       String   @default("facebook")
  score        Int      @default(0)
  stage        String   @default("cold")
  service      String?
  lastAction   String?
  nextFollowUp DateTime?
  note         String?
  // Autonomous lead agent
  channelType    String?
  channelId      String?
  handoffAt      DateTime?
  handoffMode    String?
  spaBookingId   String?
  nurtureStep    Int      @default(0)
  nurtureSentAt  DateTime?
  // Revenue attribution
  fromPostId     String?           // organic post that drove this lead
  fromCampaignId String?           // FB ad campaign that drove this lead
  fromAdId       String?           // specific ad creative
  conversations  LeadConversation[]
  bookings       BookingRevenue[]
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model BookingRevenue {
  id             String   @id @default(cuid())
  leadId         String?
  lead           Lead?    @relation(fields: [leadId], references: [id])
  bookingId      String   @unique
  customerId     String?
  service        String?
  amount         Int                              // VND
  paidAt         DateTime
  // Denormalized attribution for fast group-by queries
  fromPostId     String?
  fromCampaignId String?
  fromAdId       String?
  createdAt      DateTime @default(now())
}

model LeadConversation {
  id             String   @id @default(cuid())
  leadId         String
  lead           Lead     @relation(fields: [leadId], references: [id], onDelete: Cascade)
  senderId       String
  facebookPageId String?
  step           Int      @default(0)
  collectedName    String?
  collectedService String?
  isComplete     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model PendingApproval {
  id            String    @id @default(cuid())
  type          String
  payload       String
  status        String    @default("pending")
  shortCode     String    @unique
  zaloMessageId String?
  decidedAt     DateTime?
  timeoutAt     DateTime
  createdAt     DateTime  @default(now())
}

model AdOptimizationLog {
  id           String   @id @default(cuid())
  campaignId   String
  campaignName String
  action       String
  reason       String
  oldValue     String?
  newValue     String?
  createdAt    DateTime @default(now())
}

model ActivityLog {
  id        String   @id @default(cuid())
  type      String
  title     String
  detail    String?
  href      String?
  severity  String   @default("info")
  source    String   @default("system")
  metadata  String?
  createdAt DateTime @default(now())

  @@index([type, createdAt])
  @@index([severity, createdAt])
}

model JobRun {
  id          String    @id @default(cuid())
  name        String
  status      String    @default("running")
  trigger     String    @default("manual")
  summary     String?
  metrics     String?
  error       String?
  startedAt   DateTime  @default(now())
  completedAt DateTime?

  @@index([name, startedAt])
  @@index([status, startedAt])
}

model SpaSync {
  id                String    @id @default("1")
  lastSyncAt        DateTime?
  revenueToday      Int       @default(0)
  bookingCountToday Int       @default(0)
  lastError         String?
  lastPublishRun    DateTime?
  lastAdsOptRun     DateTime?
  updatedAt         DateTime  @updatedAt
}
